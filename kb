def cmd_add(args: argparse.Namespace) -> int:
    validate_slug(args.slug)
    destination = page_destination(args.kind, args.slug)
    if destination.exists():
        die(f"page already exists: {repo_rel(destination)}")

    domain = kb_core.normalize_tag_value(getattr(args, "domain", None) or FOUNDING_DOMAIN)
    if not domain:
        die("domain must not be empty")
    industries = normalize_metadata_list(getattr(args, "industry", None), default=FOUNDING_INDUSTRIES)
    categories = normalize_metadata_list(getattr(args, "category", None), default=default_categories_for_kind(args.kind))
    source_refs = [normalize_reference_for_page(destination, item) for item in (args.source_ref or [])]
    related = [normalize_reference_for_page(destination, item) for item in (args.related or [])]
    raw_ref: str | None = normalize_reference_for_page(destination, args.raw_ref) if args.raw_ref else None
    import_from = Path(args.import_from).expanduser().resolve() if args.import_from else None
    raw_destination: Path | None = None

    if args.kind == "source":
        if import_from and not import_from.exists():
            die(f"import source not found: {import_from}")
        if import_from:
            if args.raw_dest:
                raw_destination = normalize_repo_path(args.raw_dest)
            else:
                raw_destination = (default_raw_bucket(domain) / "inbox" / import_from.name).resolve()
            try:
                raw_destination.relative_to(RAW_ROOT)
            except ValueError as exc:
                raise SystemExit(f"error: raw destination must stay inside raw/: {raw_destination}") from exc
            raw_ref = raw_destination.relative_to(destination.parent).as_posix()
        if raw_ref:
            source_refs = [raw_ref]
        if not source_refs:
            die("source pages need `--raw-ref` or `--import-from`")

    content = build_template(args.kind, args.title, source_refs, related, domain, industries, categories)
    if args.dry_run:
        print(f"would create: {repo_rel(destination)}")
        if import_from and raw_destination is not None:
            print(f"would copy raw: {import_from} -> {repo_rel(raw_destination)}")
        print("")
        print(content)
        return 0

    if import_from and raw_destination is not None:
        ensure_parent(raw_destination)
        shutil.copy2(import_from, raw_destination)
    dump_text(destination, content)
    ensure_index_entry(destination)

    print(f"created: {repo_rel(destination)}")
    if import_from and raw_destination is not None:
        print(f"copied raw: {repo_rel(raw_destination)}")
    if args.write_log:
        log_notes = [f"Added {repo_rel(destination)}"]
        if raw_destination is not None:
            log_notes.append(f"Imported {repo_rel(raw_destination)}")
        if args.dry_run:
            print("would append log:")
            print(write_log_entry("ingest", f"add {destination.stem}", log_notes, dry_run=True))
        else:
            write_log_entry("ingest", f"add {destination.stem}", log_notes, dry_run=False)
            print(f"log updated: {repo_rel(LOG_PATH)}")
    print("next:")
    print(f"- {REPO_ROOT / 'kb'} log ingest --summary \"add {destination.stem}\" --note \"Added {repo_rel(destination)}\"")
    print(f"- {REPO_ROOT / 'kb'} maintain")
    return 0


def append_log_entry(content: str, action: str, summary: str, notes: list[str]) -> str:
    block = [f"## [{today_str()}] {action} | {summary}", ""]
    block.extend(f"- {note}" for note in notes)
    block.append("")
    suffix = "\n".join(block)
    if content.endswith("\n"):
        return content + suffix
    return content + "\n" + suffix


def write_log_entry(action: str, summary: str, notes: list[str], dry_run: bool) -> str:
    if not LOG_PATH.exists():
        die(f"log file missing: {repo_rel(LOG_PATH)}")
    if not notes:
        die("log needs at least one `--note`")
    log_page = load_page(LOG_PATH)
    current_body = log_page.body
    updated_body = append_log_entry(current_body, action, summary, notes)
    if dry_run:
        return updated_body[len(current_body):].strip()
    updated_meta = dict(log_page.meta)
    updated_meta["updated_at"] = today_str()
    dump_text(LOG_PATH, render_page(updated_meta, updated_body))
    return repo_rel(LOG_PATH)


def cmd_log(args: argparse.Namespace) -> int:
    notes = list(args.note or [])
    result = write_log_entry(args.action, args.summary, notes, dry_run=args.dry_run)
    if args.dry_run:
        print(result)
        return 0
    print(f"updated: {repo_rel(LOG_PATH)}")
    return 0


def extract_markdown_links(page: Page) -> list[tuple[str, Path]]:
    links: list[tuple[str, Path]] = []
    for raw_target in re.findall(r"\[[^\]]+\]\(([^)]+)\)", page.body):
        target = raw_target.strip()
        if target.startswith(("http://", "https://", "mailto:", "#")):
            continue
        target_path = target.split("#", 1)[0]
        if not target_path:
            continue
        resolved = (page.path.parent / target_path).resolve()
        links.append((target, resolved))
    return links


def extract_frontmatter_links(page: Page) -> list[tuple[str, Path]]:
    links: list[tuple[str, Path]] = []
    for key in ("source_refs", "related"):
        values = page.meta.get(key, [])
        if not isinstance(values, list):
            continue
        for raw_target in values:
            target = str(raw_target).strip()
            if not target:
                continue
            resolved = resolve_repo_reference(page.path, target)
            links.append((target, resolved))
    return links


def path_within(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def duplicate_resolved_refs(page: Page, key: str) -> list[str]:
    values = page.meta.get(key, [])
    if not isinstance(values, list):
        return []

    duplicates: list[str] = []
    seen: set[str] = set()
    for raw_value in values:
        target = str(raw_value).strip()
        if not target:
            continue
        resolved = resolve_repo_reference(page.path, target)
        try:
            normalized = repo_rel(resolved)
        except ValueError:
            normalized = str(resolved)
        if normalized in seen and normalized not in duplicates:
            duplicates.append(normalized)
            continue
        seen.add(normalized)
    return duplicates


def resolved_frontmatter_refs(page: Page, key: str) -> list[tuple[str, Path]]:
    values = page.meta.get(key, [])
    if not isinstance(values, list):
        return []
    refs: list[tuple[str, Path]] = []
    for raw_value in values:
        target = str(raw_value).strip()
        if not target:
            continue
        refs.append((target, resolve_repo_reference(page.path, target)))
    return refs


def page_reference_targets(page: Page) -> set[Path]:
    targets = {resolved for _, resolved in extract_markdown_links(page)}
    targets.update(resolved for _, resolved in extract_frontmatter_links(page))
    return targets


